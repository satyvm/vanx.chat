# Database
POSTGRES_USER=vanx
POSTGRES_PASSWORD=vanx
POSTGRES_DB=vanx
POSTGRES_PORT=5432

# Application ports exposed on the host
API_PORT=3001
WEB_PORT=3000
WWW_PORT=4321

# API service
DATABASE_URL="postgresql://vanx:vanx@postgres:5432/vanx"
JWT_SECRET=local-dev-secret
JWT_ACCESS_EXPIRES_IN=30m
JWT_REFRESH_EXPIRES_IN=7d
REFRESH_COOKIE_MAX_AGE=62400
WEB_APP_URL=http://localhost:3000

# Web app (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
NEXT_PUBLIC_GA_ID=
