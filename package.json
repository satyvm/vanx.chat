{
  "name": "vanx.chat",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "build:prd": "NODE_ENV=production turbo run build",
    "build:prd:doppler": "doppler run --config prd -- turbo run build",
    "build:stg": "NODE_ENV=staging turbo run build",
    "build:stg:doppler": "doppler run --config stg -- turbo run build",
    "check-types": "turbo run check-types",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "clean:all": "turbo run clean && find . -name 'node_modules' -type d -prune -exec rm -rf '{}' + && find . -name '.turbo' -type d -prune -exec rm -rf '{}' +",
    "clean:cache": "find . -name '.turbo' -type d -prune -exec rm -rf '{}' +",
    "commit": "commit",
    "dev": "turbo run dev",
    "dev:doppler": "doppler run --config dev -- turbo run dev",
    "dev:stg": "NODE_ENV=staging turbo run dev",
    "dev:stg:doppler": "doppler run --config stg -- turbo run dev",
    "docker:down": "docker compose down",
    "docker:rebuild": "docker compose build --no-cache && docker compose up -d",
    "docker:up": "docker compose up -d --build",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "lint": "turbo run lint",
    "prepare": "husky",
    "start": "turbo run start",
    "start:doppler": "doppler run -- turbo run start"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "bash -c 'pnpm turbo lint --filter=...[HEAD]'",
      "prettier --write"
    ],
    "*.astro": [
      "bash -c 'pnpm turbo lint --filter=@vanx/www...[HEAD]'",
      "prettier --write --plugin=prettier-plugin-astro"
    ],
    "*.{json,md,yml,yaml}": "prettier --write",
    "package.json": "sort-package-json"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@commitlint/prompt-cli": "^20.1.0",
    "@vanx/eslint-config": "workspace:*",
    "@vanx/typescript-config": "workspace:*",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.4",
    "prettier": "^3.6.2",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "sort-package-json": "^3.4.0",
    "turbo": "^2.5.8",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@10.18.3",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core"
    ]
  }
}
