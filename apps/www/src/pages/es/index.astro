---
import Layout from '@/layouts/Layout.astro'
import { getLangFromUrl, useTranslations } from '@/i18n/utils'
import LanguageSelector from '@/components/LanguageSelector.astro'
import { Brain, Users, Zap, Workflow } from 'lucide-react'

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
---

<Layout title={t('home.title') as string} description={t('home.description') as string}>
	<main>
		<section class="container mt-20 flex flex-col gap-6 px-6 py-8">
			<div class="flex flex-col gap-2">
				<h1 class="font-heading text-5xl font-bold">
					{t('home.hero.headline')}
				</h1>
				<h2 class="font-heading text-2xl font-medium text-pretty">
					{t('home.hero.subheadline')}
				</h2>
			</div>

			<!-- CTA Buttons
			<div class="my-6 flex flex-col gap-4 sm:flex-row sm:gap-6">
				<a
					href="#"
					class="inline-flex items-center justify-center rounded-xl bg-black px-8 py-4 text-white font-medium transition-all duration-300 hover:bg-gray-800"
				>
					{t('home.cta.primary')}
				</a>
				<a
					href="#features"
					class="inline-flex items-center justify-center rounded-xl border-2 border-black px-8 py-4 font-medium transition-all duration-300 hover:bg-black hover:text-white"
				>
					{t('home.cta.secondary')}
				</a>
			</div> -->

			<!-- Features Grid -->
			<div id="features" class="my-10 grid grid-flow-row gap-6 md:grid-cols-2">
				<div class="border-opacity-40 flex w-full flex-col gap-6 rounded-2xl border-[1px] border-dashed border-black p-8">
					<Brain size={40} absoluteStrokeWidth />
					<h3 class="font-heading text-xl font-medium">
						{t('home.content.1.title')}
					</h3>
					<p>
						{t('home.content.1.description')}
					</p>
				</div>
				<div class="border-opacity-40 flex w-full flex-col gap-6 rounded-2xl border-[1px] border-dashed border-black p-8">
					<Users size={40} absoluteStrokeWidth />
					<h3 class="font-heading text-xl font-medium">
						{t('home.content.2.title')}
					</h3>
					<p>
						{t('home.content.2.description')}
					</p>
				</div>
				<div class="border-opacity-40 flex w-full flex-col gap-6 rounded-2xl border-[1px] border-dashed border-black p-8">
					<Workflow size={40} absoluteStrokeWidth />
					<h3 class="font-heading text-xl font-medium">
						{t('home.content.3.title')}
					</h3>
					<p>
						{t('home.content.3.description')}
					</p>
				</div>
				<div class="border-opacity-40 flex w-full flex-col gap-6 rounded-2xl border-[1px] border-dashed border-black p-8">
					<Zap size={40} absoluteStrokeWidth />
					<h3 class="font-heading text-xl font-medium">
						{t('home.content.4.title')}
					</h3>
					<p>
						{t('home.content.4.description')}
					</p>
				</div>
			</div>

			<!-- Footer -->
			<div class="flex flex-col items-center justify-between gap-6 sm:flex-row">
				<p class="text-sm text-gray-600">
					{t('home.footer')}
				</p>
				<LanguageSelector />
			</div>
		</section>

		<!-- App Link -->
		<a
			href="https://app.vanx.chat"
			class="fixed top-6 right-6 block rounded-2xl border-[1px] border-transparent bg-black px-6 py-4 text-center text-sm text-white transition-all duration-300 hover:border-black hover:bg-white hover:text-black"
			rel="noopener noreferrer"
			target="_blank"
		>
			<span class="relative flex flex-row items-center justify-center gap-2">
				<Brain size={20} />
				Try vanx.chat
			</span>
		</a>
	</main>
</Layout>
