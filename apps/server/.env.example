# Database (PostgreSQL URL)
DATABASE_URL=postgresql://username:password@localhost:5432/vanx_db

# Better-Auth Configuration
BETTER_AUTH_SECRET=your_secret_token  # Generate using: openssl rand -base64 32
BETTER_AUTH_URL=http://localhost:3000

# CORS Origin (Points to your frontend development port)
CORS_ORIGIN=http://localhost:3001

# AI API Key (Required for the /ai route)
GOOGLE_GENERATIVE_AI_API_KEY=your_gemini_api_key