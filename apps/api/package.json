{
  "name": "@vanx/api",
  "version": "0.0.1",
  "private": true,
  "description": "",
  "license": "UNLICENSED",
  "author": "",
  "files": [
    "dist",
    "package.json",
    "node_modules"
  ],
  "scripts": {
    "prebuild": "pnpm --filter @vanx/database build && pnpm db:generate",
    "build": "nest build",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist generated",
    "db:generate": "pnpm --filter @vanx/database db:generate",
    "db:migrate": "pnpm --filter @vanx/database db:migrate",
    "db:migrate:deploy": "pnpm --filter @vanx/database db:migrate:deploy",
    "db:migrate:reset": "pnpm --filter @vanx/database db:migrate:reset",
    "db:push": "pnpm --filter @vanx/database db:push",
    "db:seed": "pnpm --filter @vanx/database db:seed",
    "db:seed:reset": "pnpm --filter @vanx/database db:seed:reset",
    "db:studio": "pnpm --filter @vanx/database db:studio",
    "predev": "pnpm --filter @vanx/database build && pnpm db:generate",
    "dev": "nest start --watch --b swc",
    "env:check": "tsx scripts/check-env.mts",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "prestart": "pnpm db:generate",
    "start": "nest start --b swc",
    "start:debug": "nest start --debug --watch",
    "prestart:prod": "pnpm db:generate",
    "start:prod": "node dist/src/main",
    "test": "jest",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:watch": "jest --watch"
  },
  "jest": {
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "moduleNameMapper": {
      "^src/(.*)$": "<rootDir>/$1"
    },
    "rootDir": "src",
    "testEnvironment": "node",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    }
  },
  "dependencies": {
    "@ai-sdk/google": "^2.0.39",
    "@ai-sdk/groq": "^2.0.31",
    "@ai-sdk/openai": "^2.0.72",
    "@ai-sdk/provider": "^2.0.0",
    "@ai-sdk/xai": "^2.0.38",
    "@nestjs/bull": "^11.0.4",
    "@nestjs/common": "^11.1.9",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.9",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.9",
    "@nestjs/swagger": "^11.2.3",
    "@prisma/adapter-pg": "^7.0.0",
    "@vanx/database": "workspace:*",
    "ai": "^5.0.97",
    "bcrypt": "^6.0.0",
    "bull": "^4.16.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.5.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.12",
    "@nestjs/testing": "^11.1.9",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.5",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.10.1",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.15.6",
    "@types/supertest": "^6.0.3",
    "@vanx/eslint-config": "workspace:*",
    "@vanx/typescript-config": "workspace:*",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.5.0",
    "jest": "^30.2.0",
    "prettier": "^3.6.2",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.47.0"
  }
}
